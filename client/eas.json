{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": { "simulator": false },
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://192.168.1.21:8000"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mcup.fun"
      }
    },
    "production": {
      "autoIncrement": true,
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://mcup.fun"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "ascAppId": "6789055248"
      }
    }
  }
}
