{
  "expo": {
    "name": "McUp",
    "slug": "mcup",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "primaryColor": "#FF6B5B",
    "scheme": "mcup",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFF8F0"
    },
    "ios": {
      "bundleIdentifier": "vn.mcup.app",
      "appleTeamId": "HMV6A3QPKR",
      "buildNumber": "7",
      "supportsTablet": false,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.vn.mcup.app"
        ]
      },
      "infoPlist": {
        "NSMicrophoneUsageDescription": "McUp cần micro để nghe và chấm giọng bạn khi luyện tập — chỉ khi bạn bấm thu, và clip là của riêng bạn.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "vn.mcup.app",
      "versionCode": 1,
      "permissions": [
        "RECORD_AUDIO"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF6B5B"
      }
    },
    "plugins": [
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#FF6B5B"
        }
      ],
      "@bacons/apple-targets"
    ],
    "extra": {
      "revenuecat": {
        "iosKey": "",
        "androidKey": "",
        "entitlement": "pro"
      },
      "eas": {
        "projectId": "66fa27e1-5e8f-4b3f-ae53-6eea746931d4",
        "build": {
          "experimental": {
            "ios": {
              "appExtensions": [
                {
                  "targetName": "McUpWidget",
                  "bundleIdentifier": "vn.mcup.app.widget",
                  "entitlements": {
                    "com.apple.security.application-groups": [
                      "group.vn.mcup.app"
                    ]
                  }
                }
              ]
            }
          }
        }
      }
    },
    "owner": "datisekai",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/66fa27e1-5e8f-4b3f-ae53-6eea746931d4"
    }
  }
}
