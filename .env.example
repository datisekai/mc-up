# ===== McUp .env — cp thành .env rồi điền =====

# --- Bảo mật (BẮT BUỘC đổi trước khi deploy) ---
# Sinh JWT_SECRET: python3 -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=doi-secret-that-truoc-khi-deploy
POSTGRES_PASSWORD=doi-mat-khau-postgres

# --- Database ---
# LOCAL (chạy uvicorn trên máy, không Docker): dùng SQLite mặc định (để trống dòng dưới)
# VPS: docker-compose.prod.yml tự set DATABASE_URL trỏ tới service postgres.
# DATABASE_URL=postgresql+asyncpg://mcup:doi-mat-khau-postgres@localhost:5432/mcup

APP_VERSION=0.1.0

# --- Cổng backend trên VPS (bind 127.0.0.1) — nginx proxy mcup.fun vào cổng này ---
APP_PORT=3011

# --- Bảo mật & chịu tải ---
DEBUG=false                 # prod PHẢI false — không lộ chi tiết lỗi nội bộ
# CORS cho web admin/prototype khi khác origin (mobile app không cần)
ALLOWED_ORIGINS=*
# Số clip chấm ĐỒNG THỜI (ffmpeg+Whisper nặng). VPS yếu để 1-2, mạnh hơn tăng dần.
SCORING_CONCURRENCY=2
ASR_TIMEOUT_SEC=45
MAX_CLIP_MB=12
CACHE_TTL_SEC=30
# Quota: lượt chấm/user/ngày · khách mới/IP/ngày · tổng khách mới/ngày (0 = tắt)
DAILY_CLIP_LIMIT=30
GUEST_PER_IP_DAILY=5
GUEST_DAILY_TOTAL=300

# --- IAP Pro qua RevenueCat (để trống = chưa bán; admin vẫn bật Pro tay được) ---
# Secret key v1 (sk_...) từ RevenueCat → Project → API Keys. CHỈ ở backend, KHÔNG lộ ra app.
REVENUECAT_SECRET_KEY=
REVENUECAT_ENTITLEMENT=pro
# Token tự đặt, dán vào RevenueCat → Integrations → Webhooks (Authorization header) để xác thực.
REVENUECAT_WEBHOOK_TOKEN=

# --- ASR: auto | mock | whisper | google | viettel ---
ASR_PROVIDER=auto
OPENAI_API_KEY=
GOOGLE_STT_API_KEY=
VIETTEL_STT_TOKEN=
