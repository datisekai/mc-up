# ===== McUp .env — cp thành .env rồi điền =====

# --- Bảo mật (BẮT BUỘC đổi trước khi deploy) ---
# Sinh JWT_SECRET: python3 -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=doi-secret-that-truoc-khi-deploy
POSTGRES_PASSWORD=doi-mat-khau-postgres

# --- Database ---
# LOCAL (chạy uvicorn trên máy, không Docker): dùng SQLite mặc định (để trống dòng dưới)
# DOCKER/VPS: docker-compose.prod.yml tự set DATABASE_URL trỏ tới service postgres.
# DATABASE_URL=postgresql+asyncpg://mcup:doi-mat-khau-postgres@localhost:5432/mcup

APP_VERSION=0.1.0

# --- Beta hardening (nấc 2) ---
# Domain cho HTTPS tự động (Caddy). Trỏ DNS A record về IP VPS TRƯỚC khi up.
DOMAIN=api.mcup.vn
# CORS cho web admin/prototype khi khác origin (mobile app không cần)
ALLOWED_ORIGINS=*
# Quota: lượt chấm/user/ngày · khách mới/IP/ngày · tổng khách mới/ngày (0 = tắt)
DAILY_CLIP_LIMIT=30
GUEST_PER_IP_DAILY=5
GUEST_DAILY_TOTAL=300

# --- ASR: auto | mock | whisper | google | viettel ---
ASR_PROVIDER=auto
OPENAI_API_KEY=
GOOGLE_STT_API_KEY=
VIETTEL_STT_TOKEN=

# --- Object storage clip (MinIO trong compose, hoặc S3) ---
UPLOAD_DIR=./uploads
S3_ENDPOINT=http://minio:9000
S3_BUCKET=mcup-clips
S3_ACCESS_KEY=mcup
S3_SECRET_KEY=mcup12345

# --- Redis (compose tự set) ---
# REDIS_URL=redis://localhost:6379/0
